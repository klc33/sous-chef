# Shell scripts MUST use LF, even on Windows checkouts — the containers run them with `sh` (dash),
# which fails on CRLF line endings ("set: Illegal option"). Force LF regardless of platform/autocrlf.
*.sh text eol=lf

# Other files that are executed/parsed by Linux tooling inside the image; keep them LF too.
Dockerfile text eol=lf
*.sql text eol=lf
Makefile text eol=lf

# Committed seed-corpus vectors: a binary float32 matrix that would bloat the base repo as a normal
# blob. Track via Git LFS so clones/CI fetch it as an LFS object (FR-013). Run `git lfs install` once
# per machine; CI must `git lfs pull` (or checkout with LFS) before loading the seed corpus.
seeds/corpus/embeddings.npy filter=lfs diff=lfs merge=lfs -text
