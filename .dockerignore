# Keep the backend build context small and secret-free.
.git/
.github/
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Secrets must never enter an image
.env
.env.*
!.env.example
*.key
*.pem
*.pfx

# Other surfaces / offline-only trees the backend image doesn't need
widget/
dashboard/
# Keep ml/ out of the image EXCEPT the trained classifier artifact the backend serves at runtime.
# (ml/* excludes contents but not the dir, so the served model.joblib can be re-included below.)
ml/*
!ml/artifacts
ml/artifacts/*
!ml/artifacts/model.joblib
ingestion/
# evals/ IS bundled into the backend image: the operator dashboard's on-demand eval run
# (POST /admin/evals/run) invokes evals.run_evals in-process, so the runner + its data files
# (testset.csv, attempts.yaml, golden.yaml, cases.yaml) and eval_thresholds.yaml must ship. The
# Dockerfile copies them explicitly; deps it needs (yaml/joblib/sklearn) are already in the backend extra.
docs/
projectplanFolderForMd/
specs/
tests/

# Local trace store / scratch
.phoenix/
phoenix-data/
traces/
node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
