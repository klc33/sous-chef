# SousChef — example environment for local bootstrap.
# Copy to `.env` for local runs. This file holds ONLY non-secret bootstrap values.
# Real secrets (provider API keys, etc.) live in Vault — NEVER here, in code, or in an image.
#
# ── Production profile (Railway) — where each var comes from ───────────────────────────────────
# In production these are NOT read from a committed file; they are set as Railway service variables.
# The split is the same non-secret/secret split as local (contracts/secrets-keyspace.md):
#   • PLATFORM-INJECTED by the managed plugin (never typed by hand, never in Vault):
#       POSTGRES_URL, REDIS_URL  → injected by the Railway Postgres/Redis plugins.
#   • STATIC bootstrap (non-secret) Railway variables, set once per service:
#       ENV=production, VAULT_ADDR (private Vault URL), VAULT_TOKEN (bootstrap token, non-secret),
#       TRACING_PROVIDER, PHOENIX_COLLECTOR_ENDPOINT / LANGSMITH_OTLP_ENDPOINT + LANGSMITH_PROJECT,
#       LLM_PROVIDER + model knobs, WIDGET_ORIGINS (the deployed widget origin),
#       BACKEND_ADMIN_URL, OPERATOR_USERNAME, VITE_API_BASE (widget build arg = public backend origin).
#   • SECRETS → live ONLY in Vault, seeded once via scripts/seed_vault.sh (NEVER a Railway variable):
#       GROQ_API_KEY, EMBEDDINGS_API_KEY, OPENAI_API_KEY, LANGSMITH_API_KEY,
#       OPERATOR_PASSWORD_HASH, DASHBOARD_COOKIE_KEY, ADMIN_API_TOKEN, app_secret.
# Rule: if it's a key/token/hash that grants access, it is a Vault secret — not a Railway variable.

# Environment name: local | production
ENV=local

# ── Vault (dev mode locally) ──────────────────────────────────────────────────
# In local dev Vault runs in -dev mode with a fixed, throwaway root token; this is
# a non-secret bootstrap value. In production the token is injected by the platform.
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# ── Backing services (locations, not credentials) ─────────────────────────────
POSTGRES_URL=postgresql+psycopg://postgres:postgres@postgres:5432/souschef
REDIS_URL=redis://redis:6379/0

# ── Tracing ───────────────────────────────────────────────────────────────────
# Backend selector: "phoenix" (self-hosted OTLP collector — default, local dev) or "langsmith"
# (LangSmith Cloud OTLP ingest — needs no extra service; used in prod to sidestep the host service cap).
TRACING_PROVIDER=phoenix
# Phoenix collector base (used when TRACING_PROVIDER=phoenix).
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006
# LangSmith Cloud OTLP ingest (used when TRACING_PROVIDER=langsmith). Non-secret; the LANGSMITH_API_KEY
# is a SECRET that lives ONLY in Vault (see below). Project is the LangSmith project name traces land in.
LANGSMITH_OTLP_ENDPOINT=https://api.smith.langchain.com/otel
LANGSMITH_PROJECT=souschef

# ── Provider keys (NOT set here) ──────────────────────────────────────────────
# GROQ_API_KEY, EMBEDDINGS_API_KEY, OPENAI_API_KEY, and LANGSMITH_API_KEY are secrets and live ONLY in
# Vault. To seed real keys locally, export them in your shell and run `make seed` (see scripts/seed_vault.sh):
#   export GROQ_API_KEY=... EMBEDDINGS_API_KEY=... OPENAI_API_KEY=... LANGSMITH_API_KEY=... && make seed
# Embeddings/Groq non-secret knobs (EMBEDDINGS_BASE_URL, EMBEDDINGS_MODEL, GROQ_MODEL, GROQ_AGENT_MODEL,
# etc.) have working defaults in app/config.py; override them here only if you change provider/model.
# GROQ_MODEL = fast model for search/workflow; GROQ_AGENT_MODEL = stronger model for the meal-plan agent.

# ── Chat/agent LLM provider (non-secret; the provider-agnostic seam, 005) ─────
# LLM_PROVIDER picks which hosted provider serves chat/agent GENERATION (NOT embeddings — those keep
# their own provider). One value flips the whole app with no code change; an unknown value fails fast at
# startup. Default is groq (current behavior). To run on OpenAI: set LLM_PROVIDER=openai, seed
# OPENAI_API_KEY into Vault (export it then `make seed`), and restart. OPENAI_API_KEY is a Vault SECRET —
# never put its value here. OPENAI_MODEL / OPENAI_AGENT_MODEL are non-secret and default in app/config.py
# (both gpt-4o-mini); raise OPENAI_AGENT_MODEL (e.g. gpt-4o) only for a stronger model on the agent path.
LLM_PROVIDER=groq

# ── Operator dashboard (non-secret) ───────────────────────────────────────────
# The dashboard logs the single operator in (Streamlit cookie) and then calls the backend
# /admin/* API. Only NON-secret values live here. The operator password HASH, the cookie-signing
# key, and the shared ADMIN_API_TOKEN are secrets and live ONLY in Vault (see scripts/seed_vault.sh).
BACKEND_ADMIN_URL=http://backend:8000   # base URL the dashboard uses for /admin/* calls
OPERATOR_USERNAME=operator              # operator login name (hash + cookie key come from Vault)

# ── Cook widget (non-secret, build-time) ──────────────────────────────────────
# Base URL the React widget calls for every backend request (it carries X-Profile-ID and talks
# ONLY to this origin). Baked at Vite build time as import.meta.env.VITE_API_BASE.
VITE_API_BASE=http://localhost:8000

# ── pgAdmin (LOCAL-ONLY convenience; NOT a Vault secret, NOT deployed) ────────
# pgAdmin runs only under the docker-compose `local` profile (activated by `make up`) and is never part
# of the Railway deploy. These are its MASTER login (to pgAdmin itself), an obvious local-only
# placeholder — NOT a Vault secret, never used in production. The Postgres password it connects WITH is
# the existing dev default ('postgres'); pgAdmin prompts for it once and stores it locally.
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# The widget is a browser SPA on its OWN origin, so the backend must allow that origin via CORS.
# Comma-separated allow-list consumed by the backend (app/config.py widget_origins). Defaults cover the
# Vite dev server (5173) and `vite preview` (4173) on BOTH localhost and 127.0.0.1 (a browser treats them
# as different origins); add the deployed widget origin in production. NOTE: in local dev the widget uses
# the Vite same-origin proxy (widget/vite.config.js), so leave VITE_API_BASE empty and CORS won't matter.
WIDGET_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
