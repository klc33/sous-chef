# ─── Secrets (golden rule #4: secrets live in Vault, never in the repo) ───────
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
secrets.toml
.streamlit/secrets.toml
vault-data/
vault/file/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# uv-managed virtualenv (uv.lock + pyproject.toml ARE committed)
.venv/
venv/
env/

